# Supabase – use the SERVICE ROLE key here (not the anon key)
# The service role key bypasses RLS and allows inserts
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# BOS MCP Server – full SSE URL including the API key in the path
# Example: http://193.26.158.29:8809/YOUR_API_KEY/sse
BOS_MCP_URL=http://193.26.158.29:8809/YOUR_API_KEY/sse

# Set to "true" to list all available BOS MCP tools and exit without importing
# Use this to discover tool names: npm run discover
LIST_TOOLS=false
